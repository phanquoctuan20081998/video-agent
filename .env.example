# Environment template for video-agent. Copy to .env and fill in real keys.
# Never commit .env with real keys.
# Stock-footage workflow: Pexels/Pixabay video + OpenRouter LLM + ElevenLabs TTS.
# No AI image/video gen (Seedance) used, so those keys are omitted.

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=

# --- Stock video ---
# Add sources below to this list once their keys are set (where needed):
#   coverr     — curated, higher production quality. Needs ENABLE_COVERR + COVERR_API_KEY.
#   nasa       — public domain, space/earth/science only. No key needed.
#   vimeo      — Creative Commons filter. Needs VIMEO_ACCESS_TOKEN.
#   wikimedia  — public domain/CC, uneven quality but huge breadth. No key needed.
STOCK_VIDEO_SOURCES=pexels,pixabay,youtube_cc
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Coverr (free tier: 50 req/hour). Get a key instantly at coverr.co/developers.
ENABLE_COVERR=false
COVERR_API_KEY=

# Vimeo (personal access token, "public" scope). Create an app at
# developer.vimeo.com/apps to generate one.
VIMEO_ACCESS_TOKEN=

# --- Voice (ElevenLabs TTS) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Background music (Jamendo, Creative Commons — free for non-commercial use) ---
# Get a client_id at devportal.jamendo.com. Falls back to a synthesized tone if unset.
JAMENDO_CLIENT_ID=

# --- YouTube (optional: trending search + upload) ---
YOUTUBE_DEVELOPER_KEY=

# --- YouTube thumbnail format ---
# AI creates the background; helpers/thumbnail.py applies this fixed channel template.
THUMBNAIL_BRAND_LABEL=DIA LY 60S
THUMBNAIL_SERIES_LABEL=GEO EXPLAINER
THUMBNAIL_ACCENT_COLOR=#FFD23F

# --- Geography autopilot review workflow ---
AUTOPILOT_DURATION_S=75
AUTOPILOT_MODE=edl
AUTOPILOT_REVIEW_EMAIL_TO=
AUTOPILOT_REVIEW_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
