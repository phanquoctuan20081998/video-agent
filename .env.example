# Environment template for video-agent. Copy to .env and fill in real keys.
# Never commit .env with real keys.
# Stock-footage workflow: Pexels/Pixabay video + OpenRouter LLM + ElevenLabs TTS.
# No AI image/video gen (Seedance) used, so those keys are omitted.

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=

# --- Stock video ---
PEXELS_API_KEY=
PIXABAY_API_KEY=

# --- Voice (ElevenLabs TTS) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- YouTube (optional: trending search + upload) ---
YOUTUBE_DEVELOPER_KEY=
